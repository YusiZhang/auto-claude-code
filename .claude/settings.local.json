{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(echo claude CLI not found:*)",
      "Bash(brew list:*)",
      "Bash(which tmux:*)",
      "Bash(brew install:*)",
      "Bash(which uv:*)",
      "Bash(uv sync:*)",
      "Bash(uv run:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ACC_TASK_ID=1 uv run --project /Users/yusizhang/workspace/auto-claude-code python3 -m acc.hooks",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "ACC_TASK_ID=1 uv run --project /Users/yusizhang/workspace/auto-claude-code python3 -m acc.hooks",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "ACC_TASK_ID=1 uv run --project /Users/yusizhang/workspace/auto-claude-code python3 -m acc.hooks",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
